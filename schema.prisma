generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Player {
  id           Int           @id @default(autoincrement())
  name         String
  code         String
  nameplateUrl String?
  server       String        @default("yako")
  snapshots    XSnapshot[]
  highscores   XHighScore[]
  favorites    Favorite[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([name, code, server])
  @@index([name])
  @@index([code])
}

model Weapon {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  slug        String       @unique
  type        String
  imageUrl    String?
  snapshots   XSnapshot[]
  highscores  XHighScore[]

  @@index([type])
}

model XSnapshot {
  id           Int      @id @default(autoincrement())
  playerId     Int
  weaponId     Int
  rule         String
  rank         Int
  xp           Float
  server       String   @default("yako")
  snapshotTime DateTime
  player       Player   @relation(fields: [playerId], references: [id])
  weapon       Weapon   @relation(fields: [weaponId], references: [id])

  @@index([rule, xp])
  @@index([weaponId, xp])
  @@index([snapshotTime])
}

model XHighScore {
  id          Int      @id @default(autoincrement())
  playerId    Int
  weaponId    Int
  rule        String
  highestXp   Float
  bestRank    Int
  server      String   @default("yako")
  achievedAt  DateTime
  updatedAt   DateTime @updatedAt
  player      Player   @relation(fields: [playerId], references: [id])
  weapon      Weapon   @relation(fields: [weaponId], references: [id])

  @@unique([playerId, weaponId, rule, server])
  @@index([rule, highestXp])
  @@index([weaponId, highestXp])
}

model Favorite {
  id        Int      @id @default(autoincrement())
  playerId  Int
  userKey   String
  createdAt DateTime @default(now())
  player    Player   @relation(fields: [playerId], references: [id])

  @@unique([playerId, userKey])
}
